<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/overlay_panel_bg"
    android:padding="8dp"
    android:gravity="center_vertical">

    <!-- 읽기 버튼 -->
    <ImageButton
        android:id="@+id/btnRead"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:src="@android:drawable/ic_media_play"
        android:contentDescription="화면 읽기"
        android:background="@drawable/overlay_btn_bg"
        android:layout_margin="4dp"
        android:tint="@android:color/white" />

    <!-- 중지 버튼 -->
    <ImageButton
        android:id="@+id/btnStop"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:src="@android:drawable/ic_media_pause"
        android:contentDescription="읽기 중지"
        android:background="@drawable/overlay_btn_bg"
        android:layout_margin="4dp"
        android:tint="@android:color/white" />

    <!-- AI 질문 버튼 -->
    <ImageButton
        android:id="@+id/btnAsk"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:src="@android:drawable/ic_btn_speak_now"
        android:contentDescription="AI에게 질문"
        android:background="@drawable/overlay_btn_bg_accent"
        android:layout_margin="4dp"
        android:tint="@android:color/white" />

    <!-- 닫기 버튼 -->
    <ImageButton
        android:id="@+id/btnClose"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:contentDescription="서비스 종료"
        android:background="@android:color/transparent"
        android:layout_margin="4dp"
        android:tint="#AAAAAA" />

</LinearLayout>
